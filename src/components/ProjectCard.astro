---
const { 
  title, 
  description, 
  techs = [], 
  repoUrl,
  demoUrl = null,
  featured = false,
  status = "Completado",
  type = "general",
  icon = "🚀",
  gradient = "",
  year = ""
} = Astro.props;

const getTypeColor = (type: string) => {
  const colors: Record<string, string> = {
    fullstack: "bg-purple-100 text-purple-800",
    backend: "bg-blue-100 text-blue-800",
    security: "bg-red-100 text-red-800",
    plugin: "bg-green-100 text-green-800",
    general: "bg-gray-100 text-gray-800"
  };
  return colors[type] || colors.general;
};

const getStatusColor = (status: string) => {
  const colors: Record<string, string> = {
    "En desarrollo": "bg-yellow-100 text-yellow-800",
    "Completado": "bg-green-100 text-green-800",
    "Pausado": "bg-gray-100 text-gray-800"
  };
  return colors[status] || colors["Completado"];
};
---

<div class={`group relative bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-500 transform hover:scale-[1.02] overflow-hidden w-full`}>
  <!-- Gradient header for featured projects -->
  {featured && (
    <div class={`h-2 bg-gradient-to-r ${gradient}`}></div>
  )}
  
  <!-- Content container -->
  <div class="p-6 relative">
    <!-- Featured badge - movido arriba del header -->
    {featured && (
      <div class="mb-3">
        <span class="bg-gradient-to-r from-yellow-400 to-orange-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg inline-block">
          ⭐ DESTACADO
        </span>
      </div>
    )}

    <!-- Header with icon and meta info -->
    <div class="flex items-start justify-between mb-4">
      <div class="flex items-center space-x-3">
        <div class={`w-12 h-12 rounded-xl bg-gradient-to-r ${gradient} flex items-center justify-center text-white text-xl shadow-lg`}>
          {icon}
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
            {title}
          </h3>
          <div class="flex items-center space-x-2 mt-1">
            <span class={`text-xs font-medium px-2 py-1 rounded-full ${getTypeColor(type)}`}>
              {type.charAt(0).toUpperCase() + type.slice(1)}
            </span>
            <span class="text-gray-400 text-xs">•</span>
            <span class="text-gray-500 text-xs">{year}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Description -->
    <p class="text-gray-600 mb-4 leading-relaxed text-sm">
      {description}
    </p>

    <!-- Status indicator -->
    <div class="flex items-center mb-4">
      <div class="flex items-center space-x-2">
        <div class={`w-2 h-2 rounded-full ${status === 'En desarrollo' ? 'bg-yellow-400' : 'bg-green-400'}`}></div>
        <span class={`text-xs font-medium px-2 py-1 rounded-full ${getStatusColor(status)}`}>
          {status}
        </span>
      </div>
    </div>

    <!-- Technologies -->
    <div class="mb-6">
      <div class="flex flex-wrap gap-2">
        {techs.slice(0, 4).map((tech: string) => (
          <span class="bg-gray-50 hover:bg-gray-100 text-gray-700 px-3 py-1 rounded-lg text-xs font-medium border border-gray-200 transition-colors">
            {tech}
          </span>
        ))}
        {techs.length > 4 && (
          <span class="bg-blue-50 text-blue-600 px-3 py-1 rounded-lg text-xs font-medium border border-blue-200">
            +{techs.length - 4} más
          </span>
        )}
      </div>
    </div>

    <!-- Footer with actions -->
    <div class="flex items-center justify-between pt-4 border-t border-gray-100">
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center space-x-2 text-blue-600 hover:text-blue-800 font-medium text-sm transition-colors group/link"
      >
        <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
          <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
        </svg>
        <span>Ver en GitHub</span>
        <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center space-x-1.5 text-purple-600 hover:text-purple-800 font-medium text-sm transition-all duration-300 group/demo hover:bg-purple-50 px-2 py-1 rounded-lg"
        >
          <svg class="w-3.5 h-3.5 transition-transform group-hover/demo:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          <span>Ver Demo</span>
        </a>
      )}

      <!-- GitHub stars placeholder // FOR LATER USE -->
      <div class="flex items-center space-x-1 text-gray-400 text-xs">
      </div>
    </div>
    
  </div>


  <!-- Hover effect overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-blue-600/5 to-purple-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-2xl"></div>
</div>

<style>
  /* Removed line-clamp styles since we want full description */
</style>
