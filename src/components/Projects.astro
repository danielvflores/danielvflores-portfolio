---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../const/worksInformation.js";
import { SOCIAL_LINKS } from "../const/config";
---

<section id="projects" class="py-8 lg:py-16 px-4 sm:px-6 lg:px-24">
  <!-- Profile Github -->
  <div class="flex flex-col items-center gap-6 mb-12 text-center">
    <img
      src="https://github.com/danielvflores.png"
      alt="Foto de GitHub"
      class="w-32 h-32 sm:w-40 sm:h-40 rounded-full object-cover shadow-lg"
    />
    <div class="max-w-2xl">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">
        Estás en el apartado de mis proyectos! 👋
      </h2>
      <p class="text-gray-600 text-sm sm:text-base leading-relaxed mb-4">
        Administrador de servidores VPS y desarrollador backend enfocado en Java, TypeScript y NodeJS. Mi
        enfoque está en crear proyectos eficientes y seguros. Como
        Trainee en constante crecimiento, cada proyecto es una oportunidad para
        aplicar mejores prácticas y arquitecturas sólidas que voy aprendiendo
        con el tiempo.
      </p>
      <a
        href={SOCIAL_LINKS.github}
        class="text-blue-600 hover:underline text-sm sm:text-base inline-block"
        target="_blank"
        rel="noopener noreferrer"
      >
        Ver perfil completo en GitHub →
      </a>
    </div>
  </div>

  <!-- Stats Section -->
  <div class="max-w-4xl mx-auto mb-12">
    <div class="flex justify-center gap-24 text-center">
      <div>
        <div class="text-2xl font-semibold text-gray-900">{projects.length}</div>
        <div class="text-sm text-gray-500">Proyectos</div>
      </div>
      <div>
        <div class="text-2xl font-semibold text-gray-900">8+</div>
        <div class="text-sm text-gray-500">Tecnologías</div>
      </div>
      <div>
        <div class="text-2xl font-semibold text-gray-900">100%</div>
        <div class="text-sm text-gray-500">Open Source</div>
      </div>
      <div>
        <div class="text-2xl font-semibold text-gray-900">2 años</div>
        <div class="text-sm text-gray-500">Experiencia</div>
      </div>
    </div>
  </div>

  <!-- Projects Grid -->
  <!--
    Functions not used:
    - featured={project.featured}
   -->
  <div class="grid gap-6 grid-cols-1 md:grid-cols-2 xl:grid-cols-3 max-w-6xl mx-auto justify-center">
    {projects.map(project => (
      <div class="flex justify-center">
        <ProjectCard
          title={project.title}
          description={project.description}
          techs={project.techs}
          repoUrl={project.repoUrl}
          demoUrl={project.demoUrl}
          status={project.status}
          type={project.type}
          icon={project.icon}
          gradient={project.gradient}
          year={project.year}
        />
      </div>
    ))}
  </div>
</section>
