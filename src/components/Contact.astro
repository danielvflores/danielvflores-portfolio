---
import { PERSONAL_INFO } from '../const/config';
---

<section id="contact" class="max-w-4xl mx-auto my-12 lg:my-20 px-4 sm:px-6">
  <!-- Header -->
  <div class="text-center mb-12">
    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
      ¡Trabajemos Juntos! 🚀
    </h2>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      ¿Tienes un proyecto en mente? Me encantaría conocer tus ideas y ayudarte a hacerlas realidad.
    </p>
  </div>

  <div class="grid lg:grid-cols-2 gap-10 items-start">
    
    <!-- Info -->
    <div class="space-y-6">
      <div class="border border-gray-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">
          Contacto
        </h3>

        <div class="space-y-3 text-sm text-gray-700">
          <div class="flex items-center gap-2">
            <span class="text-gray-500">Correo:</span>
            <span>{PERSONAL_INFO.email}</span>
          </div>

          <div class="flex items-center gap-2">
            <span class="text-gray-500">Ubicación:</span>
            <span>Chile</span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex gap-3">

        <!-- Enviar correo -->
        <a 
          href={`https://mail.google.com/mail/?view=cm&fs=1&to=${PERSONAL_INFO.email}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-3 py-3 bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-semibold rounded-lg shadow-md hover:from-blue-600 hover:to-cyan-600 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-75 hover:scale-[1.02] hover:shadow-lg text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l9 6 9-6M4 8v8a2 2 0 002 2h12a2 2 0 002-2V8" />
          </svg>
          Enviar correo
        </a>

        <!-- WhatsApp -->
        <a 
          href="#"
          class="inline-flex items-center px-3 py-3 bg-gradient-to-r from-green-500 to-emerald-500 text-white font-semibold rounded-lg shadow-md hover:from-green-600 hover:to-emerald-600 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-400 focus:ring-opacity-75 hover:scale-[1.02] hover:shadow-lg text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 mr-2">
            <path d="M20.52 3.48A11.82 11.82 0 0012.05 0C5.5 0 .17 5.33.17 11.88c0 2.1.55 4.14 1.6 5.96L0 24l6.32-1.66a11.87 11.87 0 005.73 1.46h.01c6.55 0 11.88-5.33 11.88-11.88 0-3.17-1.23-6.15-3.42-8.44zM12.06 21.3h-.01a9.9 9.9 0 01-5.04-1.38l-.36-.21-3.75.98 1-3.65-.23-.37a9.86 9.86 0 01-1.52-5.28c0-5.47 4.45-9.92 9.92-9.92 2.65 0 5.14 1.03 7.02 2.91a9.86 9.86 0 012.9 7.01c0 5.47-4.45 9.91-9.92 9.91zm5.44-7.39c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.47-.88-.78-1.48-1.75-1.65-2.05-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.49s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.09 4.49.71.31 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.18-1.42-.08-.12-.27-.2-.57-.35z"/>
          </svg>
          WhatsApp
        </a>

      </div>
    </div>

    <!-- Form -->
    <div class="border border-gray-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-6">
        Enviar mensaje
      </h3>

      <form 
        action="https://formspree.io/f/mvgrrydr"
        method="POST"
        class="space-y-5"
        id="contact-form"
      >

        <div>
          <label class="block text-sm text-gray-600 mb-1">
            Nombre
          </label>
          <input 
            type="text"
            name="name"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
          />
        </div>

        <div>
          <label class="block text-sm text-gray-600 mb-1">
            Email
          </label>
          <input 
            type="email"
            name="email"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
          />
        </div>

        <div>
          <label class="block text-sm text-gray-600 mb-1">
            Mensaje
          </label>
          <textarea 
            name="message"
            rows="4"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
          ></textarea>
        </div>

        <!-- Botón enviar -->
        <button 
          type="submit"
          class="inline-flex items-center justify-center px-3 py-3 bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-semibold rounded-lg shadow-md hover:from-blue-600 hover:to-cyan-600 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-75 hover:scale-[1.02] hover:shadow-lg text-sm w-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
          Enviar mensaje
        </button>

      </form>
    </div>
  </div>
</section>